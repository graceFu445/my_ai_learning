[
  {
    "id": "faq_d5a84f4b7c62466da407e4cf12351f72",
    "question": "如何退货？",
    "answer": "签收后7天内可申请退货。",
    "tags": [
      "售后",
      "退货"
    ],
    "created_at": "2026-07-07T02:07:33.037999+00:00",
    "updated_at": "2026-07-07T02:07:33.037999+00:00"
  },
  {
    "id": "faq_d335838667344077a3d8872ceee338ad",
    "question": "如何申请退货？",
    "answer": "商品签收后7天内可申请退货。请在订单详情页点击“申请售后”，选择退货原因并提交申请，客服会在1个工作日内审核。",
    "tags": [
      "售后",
      "退货"
    ],
    "created_at": "2026-07-07T04:11:55.809430+00:00",
    "updated_at": "2026-07-07T04:11:55.809430+00:00"
  },
  {
    "id": "faq_fa2856df54a241c2990d5115269783aa",
    "question": "退货需要承担运费吗？",
    "answer": "因商品质量问题导致的退货由商家承担运费；因个人原因退货，运费通常由用户自行承担，具体以订单售后页面展示为准。",
    "tags": [
      "售后",
      "退货",
      "运费"
    ],
    "created_at": "2026-07-07T04:11:55.809987+00:00",
    "updated_at": "2026-07-07T04:11:55.809987+00:00"
  },
  {
    "id": "faq_8f5a54be65c74d6b8b75b00e9bf9a35e",
    "question": "退款多久能到账？",
    "answer": "退款审核通过后，通常会在1到3个工作日内原路退回。不同支付渠道到账时间可能略有差异。",
    "tags": [
      "售后",
      "退款"
    ],
    "created_at": "2026-07-07T04:11:55.810444+00:00",
    "updated_at": "2026-07-07T04:11:55.810444+00:00"
  },
  {
    "id": "faq_03b1499f9b27417692c100019e0cfb09",
    "question": "商品可以换货吗？",
    "answer": "支持换货的商品可在签收后7天内申请换货。请保持商品、配件、包装和发票完整，具体是否支持以商品详情页说明为准。",
    "tags": [
      "售后",
      "换货"
    ],
    "created_at": "2026-07-07T04:11:55.810881+00:00",
    "updated_at": "2026-07-07T04:11:55.810881+00:00"
  },
  {
    "id": "faq_feb6d4f7f3f54be6847594d3e45ae3a1",
    "question": "配送时间一般多久？",
    "answer": "普通地区通常1到3天送达，偏远地区可能需要3到7天。实际配送时间会受库存、天气和物流情况影响。",
    "tags": [
      "配送",
      "时效"
    ],
    "created_at": "2026-07-07T04:11:55.811329+00:00",
    "updated_at": "2026-07-07T04:11:55.811329+00:00"
  },
  {
    "id": "faq_e1590bb934d343f59975b0c73118bb52",
    "question": "如何查看物流信息？",
    "answer": "进入“我的订单”，选择对应订单后点击“查看物流”，即可查看包裹的最新运输状态和快递单号。",
    "tags": [
      "配送",
      "物流"
    ],
    "created_at": "2026-07-07T04:11:55.811786+00:00",
    "updated_at": "2026-07-07T04:11:55.811786+00:00"
  },
  {
    "id": "faq_887e49e0156a41a2aa618a6c6417243a",
    "question": "可以修改收货地址吗？",
    "answer": "订单未发货前通常可以修改收货地址。请进入订单详情页点击“修改地址”；如果订单已发货，需要联系快递或客服协助处理。",
    "tags": [
      "配送",
      "地址"
    ],
    "created_at": "2026-07-07T04:11:55.812250+00:00",
    "updated_at": "2026-07-07T04:11:55.812250+00:00"
  },
  {
    "id": "faq_6b958b460d6743b399842fde68f8526b",
    "question": "支持哪些支付方式？",
    "answer": "目前支持银行卡、支付宝、微信支付等常见支付方式。具体可用支付方式以结算页展示为准。",
    "tags": [
      "支付"
    ],
    "created_at": "2026-07-07T04:11:55.812736+00:00",
    "updated_at": "2026-07-07T04:11:55.812736+00:00"
  },
  {
    "id": "faq_1b50a676b5714709a4787109e7aa0cd0",
    "question": "支付失败怎么办？",
    "answer": "请先确认网络状态、账户余额和银行卡限额。如果仍然失败，可以更换支付方式或稍后重试。",
    "tags": [
      "支付",
      "异常"
    ],
    "created_at": "2026-07-07T04:11:55.813354+00:00",
    "updated_at": "2026-07-07T04:11:55.813354+00:00"
  },
  {
    "id": "faq_93bcde68f7614aac8d1dd9ae3f5f599b",
    "question": "如何开具发票？",
    "answer": "订单完成后可在订单详情页申请发票，填写发票抬头、税号和接收邮箱后提交。电子发票通常会发送到预留邮箱。",
    "tags": [
      "发票"
    ],
    "created_at": "2026-07-07T04:11:55.813921+00:00",
    "updated_at": "2026-07-07T04:11:55.813921+00:00"
  },
  {
    "id": "faq_439db7f6c1684040848723a1d2b7fa82",
    "question": "发票信息填错了可以修改吗？",
    "answer": "发票未开具前可以在申请页面修改；如果已经开具，请联系客服确认是否支持重开。",
    "tags": [
      "发票",
      "修改"
    ],
    "created_at": "2026-07-07T04:11:55.814459+00:00",
    "updated_at": "2026-07-07T04:11:55.814459+00:00"
  },
  {
    "id": "faq_ac5f6ffc56e646cb894caf2017287184",
    "question": "忘记登录密码怎么办？",
    "answer": "在登录页点击“忘记密码”，按照手机号或邮箱验证码提示完成身份验证后，即可重置密码。",
    "tags": [
      "账户",
      "密码"
    ],
    "created_at": "2026-07-07T04:11:55.815026+00:00",
    "updated_at": "2026-07-07T04:11:55.815026+00:00"
  },
  {
    "id": "faq_fbc278b4406b4e74b2ec4bef92430fce",
    "question": "如何修改绑定手机号？",
    "answer": "登录后进入“账户设置”，选择“手机号管理”，通过原手机号或身份验证后可以绑定新的手机号。",
    "tags": [
      "账户",
      "手机号"
    ],
    "created_at": "2026-07-07T04:11:55.815591+00:00",
    "updated_at": "2026-07-07T04:11:55.815591+00:00"
  },
  {
    "id": "faq_143ca40ca79a4c988e52994aba2df8ab",
    "question": "会员积分怎么获得？",
    "answer": "用户完成下单、评价或参与平台活动时可能获得积分。积分规则会根据活动变化，具体以会员中心说明为准。",
    "tags": [
      "会员",
      "积分"
    ],
    "created_at": "2026-07-07T04:11:55.816160+00:00",
    "updated_at": "2026-07-07T04:11:55.816160+00:00"
  },
  {
    "id": "faq_4d2fb0881ffb486a99ff90f0c5f61dbf",
    "question": "优惠券为什么不能使用？",
    "answer": "优惠券可能存在使用门槛、有效期、适用商品或活动限制。请在结算页查看不可用原因。",
    "tags": [
      "优惠券",
      "支付"
    ],
    "created_at": "2026-07-07T04:11:55.816745+00:00",
    "updated_at": "2026-07-07T04:11:55.816745+00:00"
  },
  {
    "id": "faq_3d9b460e96ac4b0baed364c4455d4b10",
    "question": "订单提交后还能取消吗？",
    "answer": "订单未发货前通常可以取消。请进入订单详情页点击“取消订单”；如果订单已发货，需要等待签收后再申请退货。",
    "tags": [
      "订单",
      "取消"
    ],
    "created_at": "2026-07-07T04:11:55.817510+00:00",
    "updated_at": "2026-07-07T04:11:55.817510+00:00"
  },
  {
    "id": "faq_0fc6dab3943b4ef08e1d576eba95a275",
    "question": "取消订单后多久退款？",
    "answer": "订单取消成功后，系统通常会在1到3个工作日内按原支付渠道退款，具体到账时间以支付机构处理为准。",
    "tags": [
      "订单",
      "退款"
    ],
    "created_at": "2026-07-07T04:11:55.818115+00:00",
    "updated_at": "2026-07-07T04:11:55.818115+00:00"
  },
  {
    "id": "faq_3b5326821b164e9093d1c50403765398",
    "question": "为什么订单一直待付款？",
    "answer": "待付款表示订单尚未完成支付。请在订单有效期内完成支付，超时未支付的订单会自动关闭。",
    "tags": [
      "订单",
      "支付"
    ],
    "created_at": "2026-07-07T04:11:55.818771+00:00",
    "updated_at": "2026-07-07T04:11:55.818771+00:00"
  },
  {
    "id": "faq_d58a3f1151ee4586a90d8d0a4671d6be",
    "question": "订单关闭后还能恢复吗？",
    "answer": "已关闭订单通常无法恢复。你可以重新选择商品下单，如果优惠活动已结束，价格和优惠可能会发生变化。",
    "tags": [
      "订单",
      "关闭"
    ],
    "created_at": "2026-07-07T04:11:55.819602+00:00",
    "updated_at": "2026-07-07T04:11:55.819602+00:00"
  },
  {
    "id": "faq_1364a99d71dc4a0fb175c263b7d7febc",
    "question": "如何修改订单商品数量？",
    "answer": "订单提交后通常不能直接修改商品数量。建议取消未发货订单后重新下单，或联系客服确认是否可协助处理。",
    "tags": [
      "订单",
      "修改"
    ],
    "created_at": "2026-07-07T04:11:55.820534+00:00",
    "updated_at": "2026-07-07T04:11:55.820534+00:00"
  },
  {
    "id": "faq_d8453a66f4aa4d609801bffa5c9b4aee",
    "question": "商品显示缺货怎么办？",
    "answer": "商品缺货时可以点击“到货提醒”。系统会在商品补货后通过站内消息、短信或邮件通知你。",
    "tags": [
      "库存",
      "到货提醒"
    ],
    "created_at": "2026-07-07T04:11:55.821339+00:00",
    "updated_at": "2026-07-07T04:11:55.821339+00:00"
  },
  {
    "id": "faq_d9de10196fb347119c43ac7b08e4a078",
    "question": "预售商品什么时候发货？",
    "answer": "预售商品会在商品详情页标注预计发货时间。实际发货时间以页面说明和订单通知为准。",
    "tags": [
      "库存",
      "预售",
      "发货"
    ],
    "created_at": "2026-07-07T04:11:55.822106+00:00",
    "updated_at": "2026-07-07T04:11:55.822106+00:00"
  },
  {
    "id": "faq_8d23af527e8c46dd968dd95157dd692e",
    "question": "收到的商品少件怎么办？",
    "answer": "请先核对包裹内配件清单和外包装。如确认少件，请拍照保留包装和商品，并在订单售后页提交少件反馈。",
    "tags": [
      "售后",
      "少件"
    ],
    "created_at": "2026-07-07T04:11:55.822875+00:00",
    "updated_at": "2026-07-07T04:11:55.822875+00:00"
  },
  {
    "id": "faq_ecf81544472f4c6b91611508990970f3",
    "question": "收到破损商品怎么办？",
    "answer": "如商品运输破损，请在签收后尽快拍照留证，并在订单详情页申请售后，选择“商品破损”作为原因。",
    "tags": [
      "售后",
      "破损"
    ],
    "created_at": "2026-07-07T04:11:55.823686+00:00",
    "updated_at": "2026-07-07T04:11:55.823686+00:00"
  },
  {
    "id": "faq_de7979cf1ae742f0ba56f9f1ef922657",
    "question": "商品与描述不符怎么办？",
    "answer": "如果收到的商品与页面描述明显不一致，请提交售后申请并上传商品照片、订单截图等凭证，客服会协助核实。",
    "tags": [
      "售后",
      "描述不符"
    ],
    "created_at": "2026-07-07T04:11:55.824485+00:00",
    "updated_at": "2026-07-07T04:11:55.824485+00:00"
  },
  {
    "id": "faq_08b991e5c1b44b7586d495d11b61ea71",
    "question": "售后申请在哪里查看？",
    "answer": "进入“我的订单”或“售后服务”页面，可以查看售后申请的审核状态、处理进度和客服留言。",
    "tags": [
      "售后",
      "进度"
    ],
    "created_at": "2026-07-07T04:11:55.825293+00:00",
    "updated_at": "2026-07-07T04:11:55.825293+00:00"
  },
  {
    "id": "faq_91e22455f3924d8fb721e397adab2637",
    "question": "售后审核被拒绝怎么办？",
    "answer": "你可以在售后详情页查看拒绝原因。如果有新的凭证或仍有异议，可以补充资料后重新提交或联系客服申诉。",
    "tags": [
      "售后",
      "申诉"
    ],
    "created_at": "2026-07-07T04:11:55.826115+00:00",
    "updated_at": "2026-07-07T04:11:55.826115+00:00"
  },
  {
    "id": "faq_4ebaa67ebcc84d14ad13016162933cda",
    "question": "退货商品需要保持原包装吗？",
    "answer": "退货时建议保持商品、配件、赠品、说明书和原包装完整。缺少配件或影响二次销售可能影响退款结果。",
    "tags": [
      "售后",
      "退货",
      "包装"
    ],
    "created_at": "2026-07-07T04:11:55.826961+00:00",
    "updated_at": "2026-07-07T04:11:55.826961+00:00"
  },
  {
    "id": "faq_25c15173467b432189dbe5f991c4ea74",
    "question": "赠品需要一起退回吗？",
    "answer": "如果订单包含赠品，退货时通常需要将赠品一并退回。未退回赠品可能会影响退款金额。",
    "tags": [
      "售后",
      "赠品"
    ],
    "created_at": "2026-07-07T04:11:55.827828+00:00",
    "updated_at": "2026-07-07T04:11:55.827828+00:00"
  },
  {
    "id": "faq_99ab05cae1a0453d80370abfa67f75aa",
    "question": "保修期从什么时候开始计算？",
    "answer": "保修期通常从商品签收日或发票开具日开始计算，具体以品牌售后政策和商品说明为准。",
    "tags": [
      "售后",
      "保修"
    ],
    "created_at": "2026-07-07T04:11:55.828711+00:00",
    "updated_at": "2026-07-07T04:11:55.828711+00:00"
  },
  {
    "id": "faq_3fc0fb4ee14f4fd6a7ec83754f474368",
    "question": "如何申请维修？",
    "answer": "在订单详情页点击“申请售后”，选择“维修”并填写故障描述。部分商品可能需要联系品牌官方售后处理。",
    "tags": [
      "售后",
      "维修"
    ],
    "created_at": "2026-07-07T04:11:55.829543+00:00",
    "updated_at": "2026-07-07T04:11:55.829543+00:00"
  },
  {
    "id": "faq_c416c4be6b324bdf9280348056dd48b9",
    "question": "维修需要多长时间？",
    "answer": "维修时间会根据商品类型、故障情况和维修网点处理进度而不同，通常需要7到15个工作日。",
    "tags": [
      "售后",
      "维修",
      "时效"
    ],
    "created_at": "2026-07-07T04:11:55.830413+00:00",
    "updated_at": "2026-07-07T04:11:55.830413+00:00"
  },
  {
    "id": "faq_22e2cb0265e84e1485052bdebb29d1bf",
    "question": "可以指定快递公司吗？",
    "answer": "部分订单支持选择快递公司，具体以结算页展示为准。若页面没有选择入口，则由系统或仓库分配物流。",
    "tags": [
      "配送",
      "快递"
    ],
    "created_at": "2026-07-07T04:11:55.831271+00:00",
    "updated_at": "2026-07-07T04:11:55.831271+00:00"
  },
  {
    "id": "faq_228ed90db339441181e7ca3ff0a31ea4",
    "question": "支持自提吗？",
    "answer": "部分城市和商品支持门店自提或自提点取货。请在结算页查看是否有“自提”选项。",
    "tags": [
      "配送",
      "自提"
    ],
    "created_at": "2026-07-07T04:11:55.832110+00:00",
    "updated_at": "2026-07-07T04:11:55.832110+00:00"
  },
  {
    "id": "faq_a4446a1b44da4b8b8dd8ceebae0a9ec2",
    "question": "配送可以预约时间吗？",
    "answer": "部分大件商品或同城配送支持预约时间。普通快递通常不支持精确预约，只能以快递派送安排为准。",
    "tags": [
      "配送",
      "预约"
    ],
    "created_at": "2026-07-07T04:11:55.832943+00:00",
    "updated_at": "2026-07-07T04:11:55.832943+00:00"
  },
  {
    "id": "faq_dd314609ca614f7c8f635a27bc03c157",
    "question": "快递显示已签收但没收到怎么办？",
    "answer": "请先联系快递员或查看门卫、快递柜、代收点。如果仍未找到，请联系客服协助核查物流签收记录。",
    "tags": [
      "配送",
      "签收异常"
    ],
    "created_at": "2026-07-07T04:11:55.833799+00:00",
    "updated_at": "2026-07-07T04:11:55.833799+00:00"
  },
  {
    "id": "faq_7ef068966fc14999b92d361b6751c717",
    "question": "偏远地区可以配送吗？",
    "answer": "大部分商品支持全国配送，但部分偏远地区可能无法配送或配送时效较长，具体以结算页地址校验结果为准。",
    "tags": [
      "配送",
      "偏远地区"
    ],
    "created_at": "2026-07-07T04:11:55.834773+00:00",
